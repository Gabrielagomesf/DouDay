# API Configuration
API_BASE_URL=http://192.168.1.207:3000
API_TIMEOUT=30000

# Firebase Configuration
FIREBASE_PROJECT_ID=duoday-app
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
